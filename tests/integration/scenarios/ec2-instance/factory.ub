factory: {
  description: '''>-
    Launches an EC2 instance with its dependencies: a VPC with a subnet, a security
    group, an imported key pair, and the latest Amazon Linux 2023 AMI resolved through
    the ec2-ami data source. The instance sets user data, a gp3 root volume, and required
    IMDSv2 tokens, exercising the run wait and the follow-on attribute calls across apply
    and destroy. The availability-zones and caller-identity data sources are read into
    stack outputs. The instance type, source/dest check, and stage tag come from inputs
    so the update pass can change them in place: the type through the stop-modify-start
    path, the check through a plain attribute modify, and tags through the tag sync.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: input.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    instance-type: { type: string, default: 't3.micro', description: 'Instance type to launch' }
    source-dest-check: {
      type:        optional(boolean)
      description: 'Whether the source/destination check is on; omitted, EC2 defaults it'
    }
    stage: {
      type:        optional(string)
      description: 'Stage tag value; omitted, the resources are tagged initial'
    }
  }

  data-sources: {
    ec2-ami-al2023: aws.ec2-ami {
      owners:      ['amazon']
      most-recent: true
      filters:     [{ name: 'name', values: ['al2023-ami-2023.*-kernel-*-x86_64'] }]
    }
    ec2-availability-zones-available: aws.ec2-availability-zones {
      state: 'available'
    }
    sts-caller-identity-it: aws.sts-caller-identity {}
  }

  locals: { tags: { unobin: 'instance-it', stage: input.stage ?? 'initial' } }

  resources: {
    ec2-vpc-it: aws.ec2-vpc {
      cidr-block: '10.63.0.0/16'
    }
    ec2-subnet-a: aws.ec2-subnet {
      vpc-id:               resource.ec2-vpc-it.vpc-id
      cidr-block:           '10.63.1.0/24'
      availability-zone-id: data-source.ec2-availability-zones-available.zone-ids[0]
      tags:                 local.tags
    }
    ec2-security-group-it: aws.ec2-security-group {
      name:        'unobin-it-instance'
      description: 'unobin instance integration test security group'
      vpc-id:      resource.ec2-vpc-it.vpc-id
      tags:        local.tags
    }
    ec2-key-pair-it: aws.ec2-key-pair {
      key-name: 'unobin-it-instance'
      public-key: '''>-
        ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIN8Epl+b+PuQeE0tmbfPGaBNoGtTh1rR4MpfC0g4NhEt unobin-it
        '''
      tags: local.tags
    }
    ec2-instance-it: aws.ec2-instance {
      ami:                    data-source.ec2-ami-al2023.image-id
      instance-type:          input.instance-type
      subnet-id:              resource.ec2-subnet-a.id
      vpc-security-group-ids: [resource.ec2-security-group-it.id]
      key-name:               resource.ec2-key-pair-it.key-name
      user-data:              'echo unobin'
      # The slot is optional, so the possibly-null input needs no discharge.
      source-dest-check:      input.source-dest-check
      root-block-device:      { volume-size: 8, volume-type: 'gp3' }
      metadata-options:       { http-tokens: 'required' }
      tags:                   local.tags
    }
  }

  outputs: {
    instance-id:    { value: resource.ec2-instance-it.instance-id }
    instance-state: { value: resource.ec2-instance-it.instance-state }
    private-ip:     { value: resource.ec2-instance-it.private-ip }
    key-pair-id:    { value: resource.ec2-key-pair-it.key-pair-id }
    account:        { value: data-source.sts-caller-identity-it.account }
    zone-ids:       { value: data-source.ec2-availability-zones-available.zone-ids }
    zone-names:     { value: data-source.ec2-availability-zones-available.names }
  }
}
