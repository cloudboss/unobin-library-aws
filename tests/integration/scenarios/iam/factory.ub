factory: {
  description: '''>-
    Manages an IAM role, group, user, managed policy, attachments, instance profile, and OIDC
    provider. The session duration, group and user identities, policy document, and provider
    thumbprints come from inputs so the update pass can change them in place: the role through
    UpdateRole, the group through UpdateGroup, the policy through a new default version,
    inline policies through Put calls, and the thumbprints through the rotation call.
    '''

  imports: { aws-iam: 'github.com/cloudboss/unobin-library-aws//service/iam' }

  library-configs: { aws-iam: input.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    max-session-duration: {
      type:        integer
      default:     3600
      description: 'Maximum session duration of the role in seconds'
    }
    policy-document: { type: string, description: 'JSON document of the managed policy' }
    inline-policy-document: {
      type:        string
      description: 'JSON document of the inline policies; the update pass changes it'
    }
    group-name: {
      type:        string
      default:     'unobin-it-group'
      description: 'IAM group name; the update pass changes it in place'
    }
    group-path: {
      type:        string
      default:     '/unobin/'
      description: 'IAM group path; the update pass changes it in place'
    }
    user-name: {
      type:        string
      default:     'unobin-it-user'
      description: 'IAM user name; the update pass changes it in place'
    }
    user-path: {
      type:        string
      default:     '/unobin/'
      description: 'IAM user path; the update pass changes it in place'
    }
    user-tag-value: {
      type:        string
      default:     'initial'
      description: 'IAM user tag value; the update pass changes it in place'
    }
    access-key-status: {
      type:        string
      default:     'Inactive'
      description: 'IAM access key status; the update pass changes it in place'
    }
    oidc-thumbprints: {
      type:        list(string)
      default:     ['990f4193972f2becf12ddeda5237f9c952f20d9e']
      description: 'Server certificate thumbprints of the OIDC provider'
    }
  }

  resources: {
    iam-role-it: aws-iam.role {
      role-name: 'unobin-it-role'
      assume-role-policy-document: '''\-
        {"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":
        {"Service":"ec2.amazonaws.com"},"Action":"sts:AssumeRole"}]}
        '''
      max-session-duration: input.max-session-duration
    }
    iam-policy-it: aws-iam.policy {
      policy-name:     'unobin-it-policy'
      policy-document: input.policy-document
    }
    iam-group-it: aws-iam.group {
      name: input.group-name
      path: input.group-path
    }
    iam-user-it: aws-iam.user {
      name:          input.user-name
      path:          input.user-path
      force-destroy: true
      tags:          { Scenario: 'iam', Mutable: input.user-tag-value }
    }
    iam-access-key-user-it: aws-iam.user {
      name:          'unobin-it-access-key-user'
      path:          '/unobin/'
      force-destroy: true
      tags:          { Scenario: 'iam-access-key' }
    }
    iam-access-key-it: aws-iam.access-key {
      user-name: resource.iam-access-key-user-it.name
      status:    input.access-key-status
    }
    iam-role-policy-attachment-it: aws-iam.role-policy-attachment {
      role-name:  resource.iam-role-it.role-name
      policy-arn: resource.iam-policy-it.arn
    }
    iam-group-policy-attachment-it: aws-iam.group-policy-attachment {
      group-name: resource.iam-group-it.name
      policy-arn: resource.iam-policy-it.arn
    }
    iam-user-policy-attachment-it: aws-iam.user-policy-attachment {
      user:       resource.iam-user-it.name
      policy-arn: resource.iam-policy-it.arn
    }
    iam-role-policy-it: aws-iam.role-policy {
      role-name:       resource.iam-role-it.role-name
      policy-name:     'unobin-it-inline'
      policy-document: input.inline-policy-document
    }
    iam-group-policy-it: aws-iam.group-policy {
      group-name:      resource.iam-group-it.name
      policy-name:     'unobin-it-group-inline'
      policy-document: input.inline-policy-document
    }
    iam-user-policy-it: aws-iam.user-policy {
      user-name:       resource.iam-user-it.name
      policy-name:     'unobin-it-user-inline'
      policy-document: input.inline-policy-document
    }
    iam-instance-profile-it: aws-iam.instance-profile {
      instance-profile-name: 'unobin-it-profile'
      role:                  resource.iam-role-it.role-name
    }
    iam-openid-connect-provider-it: aws-iam.openid-connect-provider {
      url:             'https://oidc.unobin-it.example.com'
      client-id-list:  ['sts.amazonaws.com']
      thumbprint-list: input.oidc-thumbprints
    }
  }

  data-sources: {
    iam-openid-connect-provider-lookup: aws-iam.openid-connect-provider {
      url: resource.iam-openid-connect-provider-it.url
    }
  }

  outputs: {
    role-arn:          { value: resource.iam-role-it.arn }
    policy-arn:        { value: resource.iam-policy-it.arn }
    group-arn:         { value: resource.iam-group-it.arn }
    group-id:          { value: resource.iam-group-it.unique-id }
    user-arn:          { value: resource.iam-user-it.arn }
    user-id:           { value: resource.iam-user-it.unique-id }
    access-key-id:     { value: resource.iam-access-key-it.access-key-id }
    access-key-status: { value: resource.iam-access-key-it.status }
    profile-arn:       { value: resource.iam-instance-profile-it.arn }
    oidc-provider-url: { value: data-source.iam-openid-connect-provider-lookup.url }
    oidc-client-ids:   { value: data-source.iam-openid-connect-provider-lookup.client-id-list }
  }
}
