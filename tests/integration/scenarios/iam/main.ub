description: '''>-
  Manages an IAM role with a managed policy, an attachment, an instance profile, and an
  OIDC provider. The session duration, policy document, and provider thumbprints come from
  inputs so the update pass can change them in place: the role through UpdateRole, the
  policy through a new default version, and the thumbprints through the rotation call.
  '''

imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

inputs: {
  max-session-duration: {
    type:        optional(integer, 3600)
    description: 'Maximum session duration of the role in seconds'
  }
  policy-document: { type: string, description: 'JSON document of the managed policy' }
  inline-policy-document: {
    type:        string
    description: 'JSON document of the inline role policy; the update pass changes it'
  }
  oidc-thumbprints: {
    type:        optional(list(string), ['990f4193972f2becf12ddeda5237f9c952f20d9e'])
    description: 'Server certificate thumbprints of the OIDC provider'
  }
}

resources: {
  aws.iam-role.it: {
    role-name: 'unobin-it-role'
    assume-role-policy-document: '''\-
      {"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":
      {"Service":"ec2.amazonaws.com"},"Action":"sts:AssumeRole"}]}
      '''
    max-session-duration: var.max-session-duration
  }
  aws.iam-policy.it: { policy-name: 'unobin-it-policy', policy-document: var.policy-document }
  aws.iam-role-policy-attachment.it: {
    role-name:  resource.aws.iam-role.it.role-name
    policy-arn: resource.aws.iam-policy.it.arn
  }
  aws.iam-role-policy.it: {
    role-name:       resource.aws.iam-role.it.role-name
    policy-name:     'unobin-it-inline'
    policy-document: var.inline-policy-document
  }
  aws.iam-instance-profile.it: {
    instance-profile-name: 'unobin-it-profile'
    role:                  resource.aws.iam-role.it.role-name
  }
  aws.iam-openid-connect-provider.it: {
    url:             'https://oidc.unobin-it.example.com'
    client-id-list:  ['sts.amazonaws.com']
    thumbprint-list: var.oidc-thumbprints
  }
}

data: {
  aws.iam-openid-connect-provider.lookup: { url: resource.aws.iam-openid-connect-provider.it.url }
}

outputs: {
  role-arn:          { value: resource.aws.iam-role.it.arn }
  policy-arn:        { value: resource.aws.iam-policy.it.arn }
  profile-arn:       { value: resource.aws.iam-instance-profile.it.arn }
  oidc-provider-url: { value: data.aws.iam-openid-connect-provider.lookup.url }
  oidc-client-ids:   { value: data.aws.iam-openid-connect-provider.lookup.client-id-list }
}
