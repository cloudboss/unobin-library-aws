stack: {
  factory: {
    inputs: {
      policy-document: '''\-
        {"Version":"2012-10-17","Statement":[{"Effect":
        "Allow","Action":["s3:GetObject"],"Resource":"*"}]}
        '''
      inline-policy-document: '''\-
        {"Version":"2012-10-17","Statement":[{"Effect":
        "Allow","Action":["s3:ListBucket"],"Resource":"*"}]}
        '''
    }
    configurations: {
      aws {}
    }
  }

  state: local {
    path: '.unobin/state'
  }

  encryption: noop {}
}
