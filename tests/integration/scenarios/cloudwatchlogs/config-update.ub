stack: {
  factory: {
    inputs: {
      name:                  'unobin-it-log-group'
      retention:             60
      filter-pattern:        '{ $.level = "info" }'
      metric-filter-pattern: '{ $.metric = "two" }'
    }
  }

  state: local {
    path: '.unobin/state'
  }

  encryption: noop {}
}
