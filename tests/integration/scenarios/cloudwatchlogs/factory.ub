factory: {
  description: '''>-
    Manages a CloudWatch Logs log group with a retention policy and tags. The retention
    comes from an input so the update pass changes it in place through the retention-policy
    reconcile, exercising the follow-on call and the tag sync across apply and destroy.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: var.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    name: { type: string, description: 'Name of the log group' }
    retention: {
      type:        integer
      default:     30
      description: 'Retention in days; the update pass changes it in place'
    }
  }

  resources: {
    cloudwatchlogs-log-group-it: aws.cloudwatchlogs-log-group {
      name:              var.name
      retention-in-days: var.retention
      log-group-class:   'STANDARD'
      tags:              { unobin: 'cloudwatchlogs-it' }
    }
  }

  outputs: { log-group-arn: { value: resource.cloudwatchlogs-log-group-it.arn } }
}
