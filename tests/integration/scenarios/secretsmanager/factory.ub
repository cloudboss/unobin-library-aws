factory: {
  description: '''>-
    Manages a Secrets Manager secret whose string value and description come from inputs
    so the update pass writes a new version through PutSecretValue and updates the
    description in place. It also creates a separate labeled secret version. The recovery
    window is zero so destroy force-deletes the secret and a re-run can recreate it.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: var.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    secret-value: {
      type:        string
      default:     'initial-secret'
      description: 'Secret string value; the update pass rotates it to a new version'
    }
    description: {
      type:        string
      default:     'unobin integration test secret'
      description: 'Secret description; the update pass changes it'
    }
    managed-version-stages: {
      type:        list(string)
      default:     ['', 'AWSPENDING', '']
      description: 'Labels for the separate version; empty entries are ignored'
    }
  }

  resources: {
    secretsmanager-secret-it: aws.secretsmanager-secret {
      name:                    'unobin-it-secret'
      description:             var.description
      secret-string:           var.secret-value
      recovery-window-in-days: 0
      tags:                    { unobin: 'secretsmanager-it' }
    }

    secretsmanager-secret-version-it: aws.secretsmanager-secret-version {
      secret-id:       resource.secretsmanager-secret-it.arn
      secret-string:   'managed-version-secret'
      version-stages:  var.managed-version-stages
    }
  }

  outputs: {
    secret-arn:        { value: resource.secretsmanager-secret-it.arn }
    secret-version-id: { value: resource.secretsmanager-secret-it.version-id }
    managed-secret-version-id: {
      value: resource.secretsmanager-secret-version-it.version-id
    }
  }
}
