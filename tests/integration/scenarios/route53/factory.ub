factory: {
  description: '''>-
    Manages a Route 53 public hosted zone and a set of records in it: a simple A record, a TXT
    record to exercise value quoting, and a weighted pair sharing one name. The zone comment
    and the A record address come from inputs so the update pass changes them in place, and
    force-destroy lets the zone tear down with its records across apply and destroy.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: input.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    zone-name: { type: string, description: 'Name of the hosted zone' }
    comment: {
      type:        optional(string)
      description: 'Comment on the zone; the update pass sets it in place'
    }
    www-address: {
      type:        string
      default:     '192.0.2.1'
      description: 'Address of the www A record; the update pass changes it'
    }
  }

  resources: {
    route53-hosted-zone-it: aws.route53-hosted-zone {
      name:          input.zone-name
      comment:       input.comment
      force-destroy: true
      tags:          { unobin: 'route53-it' }
    }
    route53-record-set-www: aws.route53-record-set {
      zone-id: resource.route53-hosted-zone-it.zone-id
      name:    'www'
      type:    'A'
      records: [input.www-address]
      ttl:     300
    }
    route53-record-set-txt: aws.route53-record-set {
      zone-id: resource.route53-hosted-zone-it.zone-id
      name:    'txt'
      type:    'TXT'
      records: ['hello from unobin']
      ttl:     300
    }
    route53-record-set-app-blue: aws.route53-record-set {
      zone-id:                 resource.route53-hosted-zone-it.zone-id
      name:                    'app'
      type:                    'A'
      records:                 ['192.0.2.10']
      ttl:                     60
      set-identifier:          'blue'
      weighted-routing-policy: { weight: 90 }
    }
    route53-record-set-app-green: aws.route53-record-set {
      zone-id:                 resource.route53-hosted-zone-it.zone-id
      name:                    'app'
      type:                    'A'
      records:                 ['192.0.2.11']
      ttl:                     60
      set-identifier:          'green'
      weighted-routing-policy: { weight: 10 }
    }
  }

  data-sources: {
    route53-zone-by-name: aws.route53-zone {
      name: resource.route53-hosted-zone-it.name
      tags: { unobin: 'route53-it' }
    }
    route53-zone-by-id: aws.route53-zone {
      zone-id: resource.route53-hosted-zone-it.zone-id
    }
  }

  outputs: {
    zone-id:              { value: resource.route53-hosted-zone-it.zone-id }
    name-servers:         { value: resource.route53-hosted-zone-it.name-servers }
    www-fqdn:             { value: resource.route53-record-set-www.fqdn }
    lookup-zone-id:       { value: data-source.route53-zone-by-name.zone-id }
    lookup-zone-arn:      { value: data-source.route53-zone-by-name.arn }
    lookup-primary-ns:    { value: data-source.route53-zone-by-name.primary-name-server }
    lookup-zone-id-by-id: { value: data-source.route53-zone-by-id.zone-id }
  }
}
