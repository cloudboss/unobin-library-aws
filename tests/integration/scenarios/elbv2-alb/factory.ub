factory: {
  description: '''>-
    Manages an internal Application Load Balancer and its dependencies: a VPC with two subnets
    and a security group, an HTTP IP target group with one registered target, the load balancer
    across both subnets, an HTTP listener that forwards to the target group, and a path-based
    listener rule. Exercises subnet create and the load-balancing create, active wait, and
    follow-on attribute, action, target registration, and tag reconcile across apply and destroy.
    The idle timeout, health check path, and rule paths come from inputs so the update pass can
    change them in place through the modify and attribute calls the create already exercises.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: var.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    idle-timeout: {
      type:        integer
      default:     120
      description: 'Idle timeout of the load balancer in seconds'
    }
    health-check-path: {
      type:        string
      default:     '/healthz'
      description: 'Path the target group health check requests'
    }
    rule-paths: {
      type:        list(string)
      default:     ['/api/*']
      description: 'Path patterns the listener rule matches'
    }
  }

  data: {
    ec2-availability-zones-available: aws.ec2-availability-zones {
      state: 'available'
    }
  }

  resources: {
    ec2-vpc-it: aws.ec2-vpc {
      cidr-block: '10.20.0.0/16'
    }
    ec2-subnet-a: aws.ec2-subnet {
      vpc-id:            resource.ec2-vpc-it.vpc-id
      cidr-block:        '10.20.1.0/24'
      availability-zone: data.ec2-availability-zones-available.names[0]
      tags:              { unobin: 'alb-it' }
    }
    ec2-subnet-b: aws.ec2-subnet {
      vpc-id:            resource.ec2-vpc-it.vpc-id
      cidr-block:        '10.20.2.0/24'
      availability-zone: data.ec2-availability-zones-available.names[1]
      tags:              { unobin: 'alb-it' }
    }
    ec2-security-group-it: aws.ec2-security-group {
      name:        'unobin-it-alb-sg'
      description: 'unobin application load balancer integration test security group'
      vpc-id:      resource.ec2-vpc-it.vpc-id
      tags:        { unobin: 'alb-it' }
    }
    elbv2-target-group-it: aws.elbv2-target-group {
      name:                          'unobin-it-alb-tg'
      target-type:                   'ip'
      port:                          80
      protocol:                      'HTTP'
      vpc-id:                        resource.ec2-vpc-it.vpc-id
      deregistration-delay:          120
      health-check-enabled:          true
      health-check-protocol:         'HTTP'
      health-check-path:             var.health-check-path
      health-check-port:             'traffic-port'
      health-check-interval-seconds: 15
      health-check-timeout-seconds:  5
      healthy-threshold-count:       3
      unhealthy-threshold-count:     3
      matcher:                       { http-code: '200-299' }
      stickiness:                    { enabled: true, type: 'lb_cookie', cookie-duration: 600 }
      tags:                          { unobin: 'alb-it' }
    }
    elbv2-target-group-attachment-it: aws.elbv2-target-group-attachment {
      target-group-arn: resource.elbv2-target-group-it.arn
      target-id:        '10.20.1.50'
      port:             8080
    }
    elbv2-load-balancer-it: aws.elbv2-load-balancer {
      name:                       'unobin-it-alb'
      internal:                   true
      load-balancer-type:         'application'
      security-groups:            [resource.ec2-security-group-it.id]
      subnets:                    [resource.ec2-subnet-a.id, resource.ec2-subnet-b.id]
      idle-timeout:               var.idle-timeout
      enable-deletion-protection: false
      enable-http2:               true
      tags:                       { unobin: 'alb-it' }
    }
    elbv2-listener-it: aws.elbv2-listener {
      load-balancer-arn: resource.elbv2-load-balancer-it.arn
      protocol:          'HTTP'
      port:              80
      default-action:    [{ type: 'forward', target-group-arn: resource.elbv2-target-group-it.arn }]
      tags:              { unobin: 'alb-it' }
    }
    elbv2-listener-rule-it: aws.elbv2-listener-rule {
      listener-arn: resource.elbv2-listener-it.arn
      priority:     100
      actions:      [{ type: 'forward', target-group-arn: resource.elbv2-target-group-it.arn }]
      conditions:   [{ path-pattern: { values: var.rule-paths } }]
      tags:         { unobin: 'alb-it' }
    }
  }

  outputs: {
    load-balancer-arn: { value: resource.elbv2-load-balancer-it.arn }
    dns-name:          { value: resource.elbv2-load-balancer-it.dns-name }
    target-group-arn:  { value: resource.elbv2-target-group-it.arn }
    listener-arn:      { value: resource.elbv2-listener-it.arn }
    rule-arn:          { value: resource.elbv2-listener-rule-it.arn }
  }
}
