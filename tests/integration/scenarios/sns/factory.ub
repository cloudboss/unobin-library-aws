factory: {
  description: '''>-
    Manages an SNS topic with a resource policy, a subscription that fans out to an SQS queue,
    and a queue policy that lets the topic deliver to the queue. The display name comes from
    an input so the update pass changes it in place through SetTopicAttributes, and the policy
    and subscription reference the sibling topic and queue ARNs through interpolation.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: var.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    display-name: {
      type:        string
      default:     'unobin integration topic'
      description: 'Display name of the topic; the update pass changes it in place'
    }
  }

  resources: {
    sns-topic-it: aws.sns-topic {
      name:         'unobin-it-topic'
      display-name: var.display-name
      tags:         { unobin: 'sns-it' }
    }
    sqs-queue-it: aws.sqs-queue {
      name: 'unobin-it-sns-target'
      tags: { unobin: 'sns-it' }
    }
    sns-topic-policy-it: aws.sns-topic-policy {
      arn: resource.sns-topic-it.arn
      policy: $'''\-
        {"Version":"2012-10-17","Statement":[{"Sid":"AllowEventBridgePublish",
        "Effect":"Allow","Principal":{"Service":"events.amazonaws.com"},
        "Action":"SNS:Publish","Resource":"{{ resource.sns-topic-it.arn }}"}]}
        '''
    }
    sqs-queue-policy-it: aws.sqs-queue-policy {
      queue-url: resource.sqs-queue-it.url
      policy: $'''\-
        {"Version":"2012-10-17","Statement":[{"Sid":"AllowSNSDelivery","Effect":"Allow","Principal":
        {"Service":"sns.amazonaws.com"},"Action":"sqs:SendMessage","Resource":"{{ resource.sqs-queue-it.arn }}
        ","Condition":{"ArnEquals":{"aws:SourceArn":"{{ resource.sns-topic-it.arn }}"}}}]}
        '''
    }
    sns-topic-subscription-it: aws.sns-topic-subscription {
      topic-arn:            resource.sns-topic-it.arn
      protocol:             'sqs'
      endpoint:             resource.sqs-queue-it.arn
      raw-message-delivery: true
    }
  }

  outputs: {
    topic-arn:        { value: resource.sns-topic-it.arn }
    subscription-arn: { value: resource.sns-topic-subscription-it.arn }
    queue-arn:        { value: resource.sqs-queue-it.arn }
  }
}
