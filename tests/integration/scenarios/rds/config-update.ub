factory: {
  inputs: {
    instance-parameters: [
      { name: 'log_connections', value: '1' },
      { name: 'log_disconnections', value: '1' },
      { name: 'log_lock_waits', value: '1' },
    ]
    aurora-max-capacity: 2.0
    backup-retention:    2
  }
  configurations: { aws.default: {} }
}

state: { @backend: local, path: '.unobin/state' }

encryption: { @key-source: noop }
