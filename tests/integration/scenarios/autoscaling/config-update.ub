stack: {
  factory: {
    inputs: {
      max-size:         2
      lt-instance-type: 't3.small'
      stage:            'updated'
      policy-cooldown:  600
      hook-timeout:     600
    }
    configurations: {
      aws {}
    }
  }

  state: local {
    path: '.unobin/state'
  }

  encryption: noop {}
}
