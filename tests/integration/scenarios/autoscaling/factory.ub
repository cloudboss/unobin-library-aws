factory: {
  description: '''>-
    Manages an Auto Scaling group and its dependencies: a VPC with a subnet, the latest
    Amazon Linux 2023 AMI resolved through the ec2-ami data source, a launch template built
    from it, and a group whose size comes from the desired-capacity input. The default of
    zero launches no instance, which suits emulators that cannot simulate one; a live run can
    raise it to launch an instance and exercise the capacity wait and the drain on destroy. A
    standalone gp3 volume exercises the EBS volume resource in the same availability zone.
    The group bounds, template instance type, and stage tag come from inputs so the update
    pass can change them in place: the group through UpdateAutoScalingGroup, the template
    through a new default version, and tags through the tag sync.
    '''

  imports: {
    aws-autoscaling: 'github.com/cloudboss/unobin-library-aws//service/autoscaling'
    aws-ec2:         'github.com/cloudboss/unobin-library-aws//service/ec2'
  }

  library-configs: {
    aws-autoscaling: input.aws-config
    aws-ec2:         input.aws-config
  }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    desired-capacity: { type: integer, default: 0 }
    max-size:         { type: integer, default: 1, description: 'Upper bound of the group' }
    lt-instance-type: {
      type:        string
      default:     't3.micro'
      description: 'Instance type the launch template declares'
    }
    stage: {
      type:        optional(string)
      description: 'Stage tag value; omitted, the resources are tagged initial'
    }
    policy-cooldown: {
      type:        integer
      default:     300
      description: 'Scaling policy cooldown in seconds; the update pass changes it'
    }
    hook-timeout: {
      type:        integer
      default:     300
      description: 'Lifecycle hook heartbeat timeout in seconds; the update pass changes it'
    }
  }

  data-sources: {
    ec2-ami-al2023: aws-ec2.ami {
      owners:      ['amazon']
      most-recent: true
      filters:     [{ name: 'name', values: ['al2023-ami-2023.*-kernel-*-x86_64'] }]
    }
    ec2-availability-zones-available: aws-ec2.availability-zones {
      state: 'available'
    }
  }

  locals: { tags: { unobin: 'autoscaling-it', stage: input.stage ?? 'initial' } }

  resources: {
    ec2-vpc-it: aws-ec2.vpc {
      cidr-block: '10.30.0.0/16'
    }
    ec2-subnet-a: aws-ec2.subnet {
      vpc-id:            resource.ec2-vpc-it.vpc-id
      cidr-block:        '10.30.1.0/24'
      availability-zone: data-source.ec2-availability-zones-available.names[0]
      tags:              local.tags
    }
    ec2-launch-template-it: aws-ec2.launch-template {
      name: 'unobin-it-asg-lt'
      data: {
        image-id:           data-source.ec2-ami-al2023.image-id
        instance-type:      input.lt-instance-type
        metadata-options:   { http-tokens: 'required' }
        tag-specifications: [{ resource-type: 'instance', tags: { unobin: 'autoscaling-it' } }]
      }
      tags: local.tags
    }
    autoscaling-group-it: aws-autoscaling.group {
      name:                'unobin-it-asg'
      min-size:            0
      max-size:            input.max-size
      desired-capacity:    input.desired-capacity
      vpc-zone-identifier: [resource.ec2-subnet-a.id]
      launch-template: {
        id:      resource.ec2-launch-template-it.launch-template-id
        version: '$Latest'
      }
      health-check-type: 'EC2'
      tags:              [{ key: 'unobin', value: 'autoscaling-it', propagate-at-launch: true }]
    }
    ec2-volume-it: aws-ec2.volume {
      availability-zone: data-source.ec2-availability-zones-available.names[0]
      size:              1
      type:              'gp3'
      tags:              local.tags
    }
    autoscaling-policy-it: aws-autoscaling.policy {
      autoscaling-group-name: resource.autoscaling-group-it.name
      name:                   'unobin-it-scale-out'
      policy-type:            'SimpleScaling'
      adjustment-type:        'ChangeInCapacity'
      scaling-adjustment:     1
      cooldown:               input.policy-cooldown
    }
    autoscaling-lifecycle-hook-it: aws-autoscaling.lifecycle-hook {
      autoscaling-group-name: resource.autoscaling-group-it.name
      name:                   'unobin-it-drain'
      lifecycle-transition:   'autoscaling:EC2_INSTANCE_TERMINATING'
      default-result:         'CONTINUE'
      heartbeat-timeout:      input.hook-timeout
    }
  }

  outputs: {
    image-id:           { value: data-source.ec2-ami-al2023.image-id }
    launch-template-id: { value: resource.ec2-launch-template-it.launch-template-id }
    group-arn:          { value: resource.autoscaling-group-it.arn }
    volume-id:          { value: resource.ec2-volume-it.volume-id }
  }
}
