description: '''>-
  Manages an EventBridge rule and a target that invokes a Lambda function, with the function, its
  execution role, and the resource permission that lets EventBridge invoke it. The rule schedule and
  state come from inputs so the update pass can change them in place through the PutRule upsert.
  '''

imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

inputs: {
  schedule: {
    type:        optional(string, 'rate(5 minutes)')
    description: 'Schedule expression of the rule'
  }
  rule-state: { type: optional(string, 'ENABLED'), description: 'Whether the rule is enabled' }
}

resources: {
  aws: {
    iam-role: {
      it: {
        role-name: 'unobin-it-eventbridge-role'
        assume-role-policy-document: '''\-
          {"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":
          {"Service":"lambda.amazonaws.com"},"Action":"sts:AssumeRole"}]}
          '''
      }
    }
    iam-policy: {
      it: {
        policy-name: 'unobin-it-eventbridge-policy'
        policy-document: '''\-
          {"Version":"2012-10-17","Statement":[{"Effect":"Allow","Action":["logs:
          CreateLogGroup","logs:CreateLogStream","logs:PutLogEvents"],"Resource":"*"}]}
          '''
      }
    }
    iam-role-policy-attachment: {
      it: {
        role-name:  resource.aws.iam-role.it.role-name
        policy-arn: resource.aws.iam-policy.it.arn
      }
    }
    lambda-function: {
      it: {
        function-name: 'unobin-it-eventbridge-function'
        role:          resource.aws.iam-role.it.arn
        runtime:       'python3.12'
        handler:       'index.handler'
        code:          { zip-file-path: '/tmp/unobin-it-eventbridge.zip' }
        tags:          { unobin: 'eventbridge-it' }
      }
    }
    eventbridge-rule: {
      it: {
        name:                'unobin-it-rule'
        schedule-expression: var.schedule
        description:         'unobin eventbridge integration test rule'
        state:               var.rule-state
        tags:                { unobin: 'eventbridge-it' }
      }
    }
    eventbridge-target: {
      it: {
        rule:      resource.aws.eventbridge-rule.it.name
        target-id: 'unobin-it-target'
        arn:       resource.aws.lambda-function.it.arn
        input:     '{"source":"unobin"}'
      }
    }
    lambda-permission: {
      it: {
        function-name: resource.aws.lambda-function.it.function-name
        statement-id:  'unobin-it-allow-events'
        action:        'lambda:InvokeFunction'
        principal:     'events.amazonaws.com'
        source-arn:    resource.aws.eventbridge-rule.it.arn
      }
    }
  }
}

outputs: {
  rule-arn:  { value: resource.aws.eventbridge-rule.it.arn }
  target-id: { value: resource.aws.eventbridge-target.it.target-id }
}
