factory: {
  description: '''>-
    Manages an S3 bucket with versioning, a public access block, a non-public bucket policy,
    EventBridge and SQS notifications, and an object. The bucket name, versioning block, and
    object body come from inputs so the update pass can change them in place: the bucket
    starts unversioned and the update enables versioning and rewrites the object body.
    '''

  imports: {
    aws-s3:  'github.com/cloudboss/unobin-library-aws//service/s3'
    aws-sqs: 'github.com/cloudboss/unobin-library-aws//service/sqs'
  }

  library-configs: {
    aws-s3:  input.aws-config
    aws-sqs: input.aws-config
  }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    bucket: { type: string, description: 'Name of the bucket' }
    versioning: {
      type:        optional(object({ status: string }))
      description: 'Versioning block for the bucket; omitted, the bucket is unversioned'
    }
    object-body: {
      type:        optional(string)
      description: 'Body of the object; omitted, the stack supplies one'
    }
  }

  resources: {
    s3-bucket-it: aws-s3.bucket {
      bucket:           input.bucket
      tags:             { unobin: 's3-it' }
      empty-on-destroy: true
      # The slot is itself optional, so the possibly-null input passes
      # through without a discharge.
      versioning:       input.versioning
      public-access-block: {
        block-public-acls:       true
        block-public-policy:     true
        ignore-public-acls:      true
        restrict-public-buckets: true
      }
    }
    s3-bucket-policy-it: aws-s3.bucket-policy {
      bucket: resource.s3-bucket-it.bucket
      policy: $'''\-
        {"Version":"2012-10-17","Statement":[{"Sid":"AllowCloudTrailGetAcl",
        "Effect":"Allow","Principal":{"Service":"cloudtrail.amazonaws.com"},
        "Action":"s3:GetBucketAcl","Resource":"{{ resource.s3-bucket-it.arn }}"}]}
        '''
    }
    sqs-queue-notification-it: aws-sqs.queue {
      name: 'unobin-it-s3-notification'
      policy: $'''\-
        {"Version":"2012-10-17","Statement":[{"Sid":"AllowS3Send","Effect":"Allow",
        "Principal":{"Service":"s3.amazonaws.com"},"Action":"sqs:SendMessage","Resource":
        "*","Condition":{"ArnLike":{"aws:SourceArn":"{{ resource.s3-bucket-it.arn }}"}}}]}
        '''
      tags: { unobin: 's3-it' }
    }
    s3-bucket-notification-it: aws-s3.bucket-notification {
      bucket:      resource.s3-bucket-it.bucket
      eventbridge: true
      queue: [
        {
          id:            'unobin-it-s3-queue'
          queue-arn:     resource.sqs-queue-notification-it.arn
          events:        ['', 's3:ObjectCreated:*', '']
          filter-prefix: 'images/'
        },
      ]
    }
    s3-object-it: aws-s3.object {
      bucket:           resource.s3-bucket-it.bucket
      key:              'hello.txt'
      body-content:     input.object-body ?? 'hello from unobin'
      content-type:     'text/plain'
      purge-on-destroy: true
    }
  }

  outputs: {
    bucket-arn:    { value: resource.s3-bucket-it.arn }
    bucket-region: { value: resource.s3-bucket-it.bucket-region }
    notification-queue-id: {
      value: resource.s3-bucket-notification-it.queue-observed-summaries[0].id
    }
    notification-queue-events: {
      value: resource.s3-bucket-notification-it.queue-observed-summaries[0].events
    }
    object-etag: { value: resource.s3-object-it.etag }
    object-key:  { value: resource.s3-object-it.key }
  }
}
