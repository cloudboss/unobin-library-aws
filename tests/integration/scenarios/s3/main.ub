description: '''>-
  Manages an S3 bucket with versioning, a public access
  block, a non-public bucket policy, and an object.
  '''

imports: { aws: 'github.com/cloudboss/unobin-library-aws@v0.0.0' }

resources: {
  aws: {
    s3-bucket: {
      it: {
        bucket:           'unobin-it-bucket'
        tags:             { unobin: 's3-it' }
        empty-on-destroy: true
        versioning:       { status: 'Enabled' }
        public-access-block: {
          block-public-acls:       true
          block-public-policy:     true
          ignore-public-acls:      true
          restrict-public-buckets: true
        }
      }
    }
    s3-bucket-policy: {
      it: {
        bucket: resource.aws.s3-bucket.it.bucket
        policy: $'''\-
          {"Version":"2012-10-17","Statement":[{"Sid":"AllowCloudTrailGetAcl",
          "Effect":"Allow","Principal":{"Service":"cloudtrail.amazonaws.com"},
          "Action":"s3:GetBucketAcl","Resource":"{{ resource.aws.s3-bucket.it.arn }}"}]}
          '''
      }
    }
    s3-object: {
      it: {
        bucket:           resource.aws.s3-bucket.it.bucket
        key:              'hello.txt'
        body-content:     'hello from unobin'
        content-type:     'text/plain'
        purge-on-destroy: true
      }
    }
  }
}

outputs: {
  bucket-arn:    { value: resource.aws.s3-bucket.it.arn }
  bucket-region: { value: resource.aws.s3-bucket.it.bucket-region }
  object-etag:   { value: resource.aws.s3-object.it.etag }
  object-key:    { value: resource.aws.s3-object.it.key }
}
