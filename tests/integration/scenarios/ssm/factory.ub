factory: {
  description: '''>-
    Manages an SSM String parameter whose value and description come from inputs so the update
    pass changes them in place through PutParameter, plus a tag set reconciled by the separate
    tag calls. The value rides the sensitive value field, exercising the masked path.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  library-configs: { aws: input.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws')
      default: {}
    }
    value: {
      type:        string
      default:     'initial'
      description: 'Parameter value; the update pass changes it'
    }
    description: {
      type:        string
      default:     'unobin integration test parameter'
      description: 'Parameter description; the update pass changes it'
    }
  }

  resources: {
    ssm-parameter-it: aws.ssm-parameter {
      name:        '/unobin/it/string'
      type:        'String'
      value:       input.value
      description: input.description
      tier:        'Standard'
      tags:        { unobin: 'ssm-it' }
    }
  }

  outputs: {
    parameter-arn:     { value: resource.ssm-parameter-it.arn }
    parameter-version: { value: resource.ssm-parameter-it.version }
  }
}
