description: '''>-
  Manages a KMS key with tags and an alias that points at it, with automatic key rotation turned on.
  '''

imports: {
  core: 'github.com/cloudboss/unobin//pkg/libraries/core'
  aws:  'github.com/cloudboss/unobin-library-aws'
}

resources: {
  aws: {
    kms-key: {
      it: {
        description:         'unobin integration test key'
        enable-key-rotation: true
        tags:                { unobin: 'kms-it' }
      }
    }
    kms-alias: {
      it: { alias-name: 'alias/unobin-it-key', target-key-id: resource.aws.kms-key.it.key-id }
    }
  }
}

outputs: {
  key-arn:              { value: resource.aws.kms-key.it.arn }
  key-id:               { value: resource.aws.kms-key.it.key-id }
  alias-arn:            { value: resource.aws.kms-alias.it.arn }
  alias-target-key-arn: { value: resource.aws.kms-alias.it.target-key-arn }
}
