factory: {
  description: '''>-
    Manages a KMS key with tags and an alias that points at it, with automatic key
    rotation turned on. The description, rotation flag, and tags come from inputs so the
    update pass can change them in place: the description through UpdateKeyDescription,
    rotation through its enable and disable calls, and tags through the tag sync.
    '''

  imports: { aws-kms: 'github.com/cloudboss/unobin-library-aws//service/kms' }

  library-configs: { aws-kms: input.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    description: {
      type:        optional(string)
      description: 'Description of the key; omitted, the stack supplies one'
    }
    rotation-enabled: {
      type:        boolean
      default:     true
      description: 'Whether automatic key rotation is on'
    }
    tags: {
      type:        optional(map(string))
      description: 'Tags for the key; omitted, the stack supplies the scenario tag'
    }
  }

  locals: {
    description: input.description ?? 'unobin integration test key'
  }

  resources: {
    kms-key-it: aws-kms.key {
      description:         local.description
      enable-key-rotation: input.rotation-enabled
      tags:                input.tags ?? { unobin: 'kms-it' }
    }
    kms-alias-it: aws-kms.alias {
      alias-name:    'alias/unobin-it-key'
      target-key-id: resource.kms-key-it.key-id
    }
  }

  outputs: {
    key-arn:              { value: resource.kms-key-it.arn }
    key-id:               { value: resource.kms-key-it.key-id }
    alias-arn:            { value: resource.kms-alias-it.arn }
    alias-target-key-arn: { value: resource.kms-alias-it.target-key-arn }
  }
}
