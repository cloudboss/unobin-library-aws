factory: {
  description: '''>-
    Manages a DynamoDB table with a composite key, a global secondary index,
    TTL, and a stream on on-demand billing, so no throughput capacity is set.
    The stage tag comes from an input so the update pass changes it in place
    through the tag sync, exercising create, the tag update, and destroy.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  inputs: {
    stage: {
      type:        string
      default:     'initial'
      description: 'Stage tag value; the update pass changes it'
    }
  }

  locals: { tags: { unobin: 'dynamodb-it', stage: var.stage } }

  resources: {
    dynamodb-table-it: aws.dynamodb-table {
      name:         'unobin-it-table'
      billing-mode: 'PAY_PER_REQUEST'
      hash-key:     'id'
      range-key:    'sort'
      attribute: [
        { name: 'id', type: 'S' },
        { name: 'sort', type: 'S' },
        { name: 'lookup', type: 'S' },
      ]
      global-secondary-index: [
        { name: 'by-lookup', hash-key: 'lookup', projection-type: 'ALL', non-key-attributes: [] },
      ]
      ttl:              { enabled: true, attribute-name: 'expires-at' }
      stream-enabled:   true
      stream-view-type: 'NEW_AND_OLD_IMAGES'
      tags:             local.tags
    }
  }

  outputs: {
    table-arn:  { value: resource.dynamodb-table-it.arn }
    stream-arn: { value: resource.dynamodb-table-it.stream-arn }
  }
}
