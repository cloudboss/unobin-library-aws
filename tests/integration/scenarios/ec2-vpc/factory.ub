factory: {
  description: '''>-
    Manages a VPC with a security group and ingress and egress rules. The
    CIDR block and ingress port range come from inputs so the update pass
    can change the rule's ports in place through ModifySecurityGroupRules.
    '''

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    cidr-block: { type: string, description: 'IPv4 CIDR block for the VPC' }
    ssh-port: {
      type:        optional(object({ from: integer, to: optional(integer) }))
      description: 'Ingress port range; omitted, port 22, and `to` falls back to `from`'
    }
  }

  imports: { aws-ec2: 'github.com/cloudboss/unobin-library-aws//service/ec2' }

  library-configs: { aws-ec2: input.aws-config }

  constraints: [
    # The null test in when narrows what require reads; the optional `to`
    # needs its own test, which narrows the comparison after the ||.
    {
      kind:    predicate
      when:    input.ssh-port != null
      require: input.ssh-port.to == null || input.ssh-port.from <= input.ssh-port.to
      message: 'ssh-port from must not exceed to'
    },
  ]

  resources: {
    ec2-vpc-it: aws-ec2.vpc {
      cidr-block: input.cidr-block
    }
    ec2-security-group-it: aws-ec2.security-group {
      name:        'unobin-it-sg'
      description: 'unobin integration test security group'
      vpc-id:      resource.ec2-vpc-it.vpc-id
      tags:        { unobin: 'ec2-it' }
    }
    ec2-security-group-ingress-rule-it: aws-ec2.security-group-ingress-rule {
      security-group-id: resource.ec2-security-group-it.id
      ip-protocol:       'tcp'
      # Each nullable level wears its own marker; ?? ends the chain.
      from-port:         input.ssh-port?.from ?? 22
      to-port:           input.ssh-port?.to ?? input.ssh-port?.from ?? 22
      cidr-ipv4:         input.cidr-block
      description:       'ssh from the vpc'
    }
    ec2-security-group-egress-rule-it: aws-ec2.security-group-egress-rule {
      security-group-id: resource.ec2-security-group-it.id
      ip-protocol:       'tcp'
      from-port:         443
      to-port:           443
      cidr-ipv4:         '0.0.0.0/0'
      description:       'https outbound'
    }
  }

  data-sources: {
    ec2-vpc-lookup: aws-ec2.vpc {
      vpc-id:     resource.ec2-vpc-it.vpc-id
      cidr-block: input.cidr-block
      filter:     [{ name: 'vpc-id', values: [resource.ec2-vpc-it.vpc-id] }]
    }
    ec2-security-group-lookup: aws-ec2.security-group {
      id:     resource.ec2-security-group-it.id
      name:   'unobin-it-sg'
      vpc-id: resource.ec2-vpc-it.vpc-id
      tags:   { unobin: 'ec2-it' }
      filter: [{ name: 'owner-id', values: [resource.ec2-security-group-it.owner-id] }]
    }
  }

  outputs: {
    vpc-id:                            { value: resource.ec2-vpc-it.vpc-id }
    security-group-id:                 { value: resource.ec2-security-group-it.id }
    ingress-rule-id: {
      value: resource.ec2-security-group-ingress-rule-it.security-group-rule-id
    }
    egress-rule-id: {
      value: resource.ec2-security-group-egress-rule-it.security-group-rule-id
    }
    lookup-vpc-id:                     { value: data-source.ec2-vpc-lookup.vpc-id }
    lookup-vpc-arn:                    { value: data-source.ec2-vpc-lookup.arn }
    lookup-vpc-cidr-block:             { value: data-source.ec2-vpc-lookup.cidr-block }
    lookup-vpc-dns-support:            { value: data-source.ec2-vpc-lookup.enable-dns-support }
    lookup-security-group-id:          { value: data-source.ec2-security-group-lookup.id }
    lookup-security-group-arn:         { value: data-source.ec2-security-group-lookup.arn }
    lookup-security-group-description: { value: data-source.ec2-security-group-lookup.description }
    lookup-security-group-name:        { value: data-source.ec2-security-group-lookup.name }
    lookup-security-group-vpc-id:      { value: data-source.ec2-security-group-lookup.vpc-id }
    lookup-security-group-tags:        { value: data-source.ec2-security-group-lookup.tags }
  }
}
