factory: {
  description: '''>-
    Manages the container stack end to end: an ECR repository whose URI feeds the task definition's
    container image, an Auto Scaling backed ECS capacity provider, an ECS cluster with a Fargate
    default capacity provider strategy, a Fargate task definition, and a service in a small VPC at a
    desired count of zero so no task has to launch. The scan-on-push flag, capacity provider managed
    draining, the strategy weight, and the service's deployment maximum percent come from inputs so
    the update pass changes each in place through its own call path: PutImageScanningConfiguration,
    UpdateCapacityProvider, PutClusterCapacityProviders, and UpdateService.
    '''

  imports: {
    aws-autoscaling: 'github.com/cloudboss/unobin-library-aws//service/autoscaling'
    aws-ec2:         'github.com/cloudboss/unobin-library-aws//service/ec2'
    aws-ecr:         'github.com/cloudboss/unobin-library-aws//service/ecr'
    aws-ecs:         'github.com/cloudboss/unobin-library-aws//service/ecs'
    aws-iam:         'github.com/cloudboss/unobin-library-aws//service/iam'
  }

  library-configs: {
    aws-autoscaling: input.aws-config
    aws-ec2:         input.aws-config
    aws-ecr:         input.aws-config
    aws-ecs:         input.aws-config
    aws-iam:         input.aws-config
  }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    scan-on-push: {
      type:        boolean
      default:     false
      description: 'ECR scan-on-push flag; the update pass enables it'
    }
    fargate-weight: {
      type:        integer
      default:     1
      description: 'Weight of the FARGATE strategy entry; the update pass changes it'
    }
    maximum-percent: {
      type:        integer
      default:     200
      description: 'Service deployment maximum percent; the update pass changes it'
    }
    provider-managed-draining: {
      type:        string
      default:     'ENABLED'
      description: 'Capacity provider managed draining; the update pass disables it'
    }
    provider-stage: {
      type:        optional(string)
      description: 'Capacity provider tag value; omitted, the provider is tagged initial'
    }
  }

  data-sources: {
    ec2-ami-al2023: aws-ec2.ami {
      owners:      ['amazon']
      most-recent: true
      filters:     [{ name: 'name', values: ['al2023-ami-2023.*-kernel-*-x86_64'] }]
    }
    ec2-availability-zones-available: aws-ec2.availability-zones {
      state: 'available'
    }
  }

  resources: {
    ec2-vpc-it: aws-ec2.vpc {
      cidr-block: '10.64.0.0/16'
    }
    ec2-subnet-a: aws-ec2.subnet {
      vpc-id:            resource.ec2-vpc-it.vpc-id
      cidr-block:        '10.64.1.0/24'
      availability-zone: data-source.ec2-availability-zones-available.names[0]
      tags:              { unobin: 'ecs-it' }
    }
    ec2-launch-template-cp: aws-ec2.launch-template {
      name: 'unobin-it-ecs-cp-lt'
      data: {
        image-id:         data-source.ec2-ami-al2023.image-id
        instance-type:    't3.micro'
        metadata-options: { http-tokens: 'required' }
      }
      tags: { unobin: 'ecs-it' }
    }
    autoscaling-group-cp: aws-autoscaling.group {
      name:                'unobin-it-ecs-cp-asg'
      min-size:            0
      max-size:            1
      desired-capacity:    0
      vpc-zone-identifier: [resource.ec2-subnet-a.id]
      launch-template: {
        id:      resource.ec2-launch-template-cp.launch-template-id
        version: '$Latest'
      }
      health-check-type: 'EC2'
      tags:              [{ key: 'unobin', value: 'ecs-it', propagate-at-launch: true }]
    }
    ecs-capacity-provider-it: aws-ecs.capacity-provider {
      name: 'unobin-it-ecs-cp'
      auto-scaling-group-provider: {
        auto-scaling-group-arn:         resource.autoscaling-group-cp.arn
        managed-draining:               input.provider-managed-draining
        managed-termination-protection: 'DISABLED'
        managed-scaling:                { status: 'ENABLED', target-capacity: 100 }
      }
      tags: {
        unobin: 'ecs-it'
        role:   'capacity-provider'
        stage:  input.provider-stage ?? 'initial'
      }
    }
    ecr-repository-repo: aws-ecr.repository {
      name:         'unobin-it-ecs'
      scan-on-push: input.scan-on-push
      lifecycle-policy: '''\-
        {"rules":[{"rulePriority":1,"description":"expire untagged images","selection":{"tagStatus":
        "untagged","countType":"imageCountMoreThan","countNumber":5},"action":{"type":"expire"}}]}
        '''
      tags: { unobin: 'ecs-it' }
    }
    ecs-cluster-it: aws-ecs.cluster {
      name:               'unobin-it-ecs'
      capacity-providers: ['FARGATE', 'FARGATE_SPOT']
      default-capacity-provider-strategy: [
        { capacity-provider: 'FARGATE', weight: input.fargate-weight },
      ]
      tags: { unobin: 'ecs-it' }
    }
    iam-role-exec: aws-iam.role {
      role-name: 'unobin-it-ecs-exec'
      assume-role-policy-document: '''\-
        {"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":
        {"Service":"ecs-tasks.amazonaws.com"},"Action":"sts:AssumeRole"}]}
        '''
    }
    iam-role-policy-attachment-exec: aws-iam.role-policy-attachment {
      role-name:  resource.iam-role-exec.role-name
      policy-arn: 'arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy'
    }
    ecs-task-definition-it: aws-ecs.task-definition {
      family:                   'unobin-it-ecs'
      cpu:                      '256'
      memory:                   '512'
      network-mode:             'awsvpc'
      requires-compatibilities: ['FARGATE']
      execution-role-arn:       resource.iam-role-exec.arn
      container-definitions: [
        {
          name:      'app'
          image:     $'''{{ resource.ecr-repository-repo.repository-uri }}:latest'''
          essential: true
        },
      ]
      tags: { unobin: 'ecs-it' }
    }
    ecs-service-it: aws-ecs.service {
      name:                     'unobin-it-ecs'
      cluster:                  resource.ecs-cluster-it.arn
      task-definition:          resource.ecs-task-definition-it.arn
      desired-count:            0
      network-configuration:    { subnets: [resource.ec2-subnet-a.id] }
      deployment-configuration: { maximum-percent: input.maximum-percent }
      tags:                     { unobin: 'ecs-it' }
    }
  }

  outputs: {
    repository-uri:        { value: resource.ecr-repository-repo.repository-uri }
    cluster-arn:           { value: resource.ecs-cluster-it.arn }
    task-definition-arn:   { value: resource.ecs-task-definition-it.arn }
    service-arn:           { value: resource.ecs-service-it.arn }
    capacity-provider-arn: { value: resource.ecs-capacity-provider-it.arn }
  }
}
