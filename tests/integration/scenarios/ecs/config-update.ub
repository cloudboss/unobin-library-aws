stack: {
  factory: {
    inputs: {
      scan-on-push:              true
      fargate-weight:            2
      maximum-percent:           150
      provider-managed-draining: 'DISABLED'
      provider-stage:            'updated'
    }
  }

  state: local {
    path: '.unobin/state'
  }

  encryption: noop {}
}
