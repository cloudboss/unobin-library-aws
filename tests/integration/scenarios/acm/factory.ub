factory: {
  description: '''>-
    Requests an ACM certificate validated by DNS and returns the validation records ACM
    assigns, the value a downstream validation resource reads. The transparency-logging
    preference and tags come from inputs so the update pass can change them in place:
    the preference through UpdateCertificateOptions and the tags through the tag sync.
    '''

  imports: { aws-acm: 'github.com/cloudboss/unobin-library-aws//service/acm' }

  library-configs: { aws-acm: input.aws-config }

  inputs: {
    aws-config: {
      type:    library-config('github.com/cloudboss/unobin-library-aws//config')
      default: {}
    }
    transparency: {
      type:        string
      default:     'ENABLED'
      description: 'Certificate transparency logging preference'
    }
    tags: {
      type:        optional(map(string))
      description: 'Tags for the certificate; omitted, the stack supplies the scenario tag'
    }
  }

  resources: {
    acm-certificate-it: aws-acm.certificate {
      domain-name:               'unobin-it.example.com'
      validation-method:         'DNS'
      subject-alternative-names: ['www.unobin-it.example.com']
      options:                   { certificate-transparency-logging-preference: input.transparency }
      tags:                      input.tags ?? { unobin: 'acm-it' }
    }
  }

  data-sources: {
    acm-certificate-lookup: aws-acm.certificate-data {
      domain:      resource.acm-certificate-it.domain-name
      tags:        { unobin: 'acm-it' }
      statuses:    ['PENDING_VALIDATION']
      most-recent: true
    }
  }

  outputs: {
    certificate-arn:           { value: resource.acm-certificate-it.arn }
    certificate-status:        { value: resource.acm-certificate-it.status }
    certificate-type:          { value: resource.acm-certificate-it.type }
    validation-options:        { value: resource.acm-certificate-it.domain-validation-options }
    lookup-certificate-arn:    { value: data-source.acm-certificate-lookup.arn }
    lookup-certificate-status: { value: data-source.acm-certificate-lookup.status }
    lookup-certificate-tags:   { value: data-source.acm-certificate-lookup.tags }
  }
}
