factory: {
  description: '''>-
    Builds a routed VPC: an internet gateway attached to the VPC, a public route table sending
    0.0.0.0/0 to the gateway and associated with a public subnet, an Elastic IP feeding a NAT
    gateway in that subnet, a private route table sending 0.0.0.0/0 to the NAT gateway and
    associated with a private subnet, and an S3 gateway endpoint on the private route table.
    Exercises the attachment fold, the route and association waits, the NAT create wait, and the
    endpoint route-table reconcile across apply and destroy. The stage tag and the endpoint's route
    tables come from inputs so the update pass can change them in place: tags through the tag sync,
    and the endpoint through ModifyVpcEndpoint when the update extends it to the public route table.
    '''

  imports: { aws: 'github.com/cloudboss/unobin-library-aws' }

  inputs: {
    stage: {
      type:        optional(string)
      description: 'Stage tag value; omitted, the resources are tagged initial'
    }
    endpoint-on-public: {
      type:        boolean
      default:     false
      description: 'Whether the S3 endpoint also rides the public route table'
    }
  }

  data: {
    ec2-availability-zones-available: aws.ec2-availability-zones {
      state: 'available'
    }
  }

  locals: {
    tags: { unobin: 'vpc-routing-it', stage: var.stage ?? 'initial' }
    endpoint-route-table-ids: if var.endpoint-on-public
      then [
        resource.ec2-route-table-private.route-table-id,
        resource.ec2-route-table-public.route-table-id,
      ]
      else [resource.ec2-route-table-private.route-table-id]
  }

  resources: {
    ec2-vpc-it: aws.ec2-vpc {
      cidr-block: '10.62.0.0/16'
    }
    ec2-subnet-public: aws.ec2-subnet {
      vpc-id:            resource.ec2-vpc-it.vpc-id
      cidr-block:        '10.62.1.0/24'
      availability-zone: data.ec2-availability-zones-available.names[0]
      tags:              local.tags
    }
    ec2-subnet-private: aws.ec2-subnet {
      vpc-id:            resource.ec2-vpc-it.vpc-id
      cidr-block:        '10.62.2.0/24'
      availability-zone: data.ec2-availability-zones-available.names[1]
      tags:              local.tags
    }
    ec2-internet-gateway-it: aws.ec2-internet-gateway {
      vpc-id: resource.ec2-vpc-it.vpc-id
      tags:   local.tags
    }
    ec2-route-table-public: aws.ec2-route-table {
      vpc-id: resource.ec2-vpc-it.vpc-id
      tags:   { unobin: 'vpc-routing-it', tier: 'public', stage: var.stage ?? 'initial' }
    }
    ec2-route-table-private: aws.ec2-route-table {
      vpc-id: resource.ec2-vpc-it.vpc-id
      tags:   { unobin: 'vpc-routing-it', tier: 'private', stage: var.stage ?? 'initial' }
    }
    ec2-route-public-default: aws.ec2-route {
      route-table-id:         resource.ec2-route-table-public.route-table-id
      destination-cidr-block: '0.0.0.0/0'
      gateway-id:             resource.ec2-internet-gateway-it.internet-gateway-id
    }
    ec2-route-private-default: aws.ec2-route {
      route-table-id:         resource.ec2-route-table-private.route-table-id
      destination-cidr-block: '0.0.0.0/0'
      nat-gateway-id:         resource.ec2-nat-gateway-it.nat-gateway-id
    }
    ec2-route-table-association-public: aws.ec2-route-table-association {
      route-table-id: resource.ec2-route-table-public.route-table-id
      subnet-id:      resource.ec2-subnet-public.id
    }
    ec2-route-table-association-private: aws.ec2-route-table-association {
      route-table-id: resource.ec2-route-table-private.route-table-id
      subnet-id:      resource.ec2-subnet-private.id
    }
    # The EIP keeps literal tags: ministack accepts AllocateAddress without
    # recording its tags, so an input-driven change would chase a value the
    # emulator never stores.
    ec2-eip-nat: aws.ec2-eip {
      tags: { unobin: 'vpc-routing-it' }
    }
    ec2-nat-gateway-it: aws.ec2-nat-gateway {
      subnet-id:     resource.ec2-subnet-public.id
      allocation-id: resource.ec2-eip-nat.allocation-id
      tags:          local.tags
    }
    ec2-vpc-endpoint-s3: aws.ec2-vpc-endpoint {
      vpc-id:          resource.ec2-vpc-it.vpc-id
      service-name:    'com.amazonaws.us-east-1.s3'
      route-table-ids: local.endpoint-route-table-ids
      tags:            local.tags
    }
  }

  outputs: {
    internet-gateway-id:    { value: resource.ec2-internet-gateway-it.internet-gateway-id }
    public-route-table-id:  { value: resource.ec2-route-table-public.route-table-id }
    private-route-table-id: { value: resource.ec2-route-table-private.route-table-id }
    eip-public-ip:          { value: resource.ec2-eip-nat.public-ip }
    nat-gateway-id:         { value: resource.ec2-nat-gateway-it.nat-gateway-id }
    vpc-endpoint-id:        { value: resource.ec2-vpc-endpoint-s3.vpc-endpoint-id }
  }
}
